# =============================================================================
# VPNOnAzure Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Azure Settings ---
# Resource group name for all VPN resources
RESOURCE_GROUP=rg-vpn-personal

# Azure region (e.g., southeastasia, eastus, westeurope)
# See: https://azure.microsoft.com/en-us/explore/global-infrastructure/geographies/
LOCATION=southeastasia

# VM size (Standard_B1s ~$8/mo, Standard_B2s ~$30/mo)
VM_SIZE=Standard_B2s

# VM name
VM_NAME=vm-wireguard

# --- WireGuard Settings ---
# Number of WireGuard peer configs to generate (1-10)
PEER_COUNT=6

# DNS servers for VPN clients (comma-separated)
DNS_SERVERS="1.1.1.1, 8.8.8.8"

# WireGuard listen port (443 recommended to bypass GFW; default is 51820)
WG_PORT=443

# --- SSH ---
# Path to SSH public key for VM authentication (auto-detected if not set)
# SSH_KEY_FILE=~/.ssh/id_ed25519.pub

# --- Optional ---
# Restrict SSH access to a specific IP (CIDR notation, default: allow any)
# ALLOW_SSH_FROM=1.2.3.4

# DNS label for public IP (gives you <label>.<region>.cloudapp.azure.com)
# DNS_LABEL=myvpn

# Server endpoint override (auto-detected from Azure if not set)
# VPN_ENDPOINT=1.2.3.4
